# Copia este archivo a .env y ajusta los valores antes de desplegar:
#   cp docker/.env.example docker/.env

# Puerto HTTP expuesto en el VPS (usa 80 o 8080 si 80 está ocupado)
HTTP_PORT=80

# SQL Server — mínimo 8 caracteres, mayúsculas, minúsculas, números y símbolos
MSSQL_SA_PASSWORD=CambiarPorPasswordSeguro123!

# JWT — mínimo 32 caracteres
JWT_KEY=CambiarPorClaveJwtSeguraDeAlMenos32Caracteres
JWT_ISSUER=Clinica
JWT_AUDIENCE=Clinica
JWT_EXPIRES_HOURS=8
JWT_REFRESH_DAYS=7

# Usuario administrador inicial (se crea en el primer arranque)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@clinica.com
ADMIN_PASSWORD=CambiarPorPasswordAdmin123!

# Origen del frontend para CORS (URL pública del VPS, con http/https)
FRONTEND_ORIGIN=http://tu-dominio-o-ip

# Usuarios demo (recomendado false en producción)
SEED_DEMO_USERS=false
