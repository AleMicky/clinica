# Copia este archivo a .env y ajusta los valores antes de desplegar:
#   cp docker/.env.example docker/.env

# SQL Server externo (no se levanta contenedor SQL en producción)
SQLSERVER_CONNECTION_STRING=Server=TU_HOST,1433;Database=db_clinica;User Id=sa;Password=CambiarPorPasswordSeguro123!;Encrypt=True;TrustServerCertificate=True;MultipleActiveResultSets=True

# JWT — mínimo 32 caracteres
JWT_KEY=CambiarPorClaveJwtSeguraDeAlMenos32Caracteres
JWT_ISSUER=Clinica
JWT_AUDIENCE=Clinica
JWT_EXPIRES_HOURS=8
JWT_REFRESH_DAYS=7

# Usuario administrador inicial (se crea en el primer arranque)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@clinica.com
ADMIN_PASSWORD=CambiarPorPasswordAdmin123!

# Origen del frontend para CORS (infraestructura-nginx:9000)
FRONTEND_ORIGIN=http://157.173.99.216:9000

# Usuarios demo (recomendado false en producción)
SEED_DEMO_USERS=false
